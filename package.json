{
  "name": "application-tracker",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm --workspace server run dev",
    "dev:client": "npm --workspace client run dev",
    "dev:all": "npm --workspace server run dev & npm --workspace client run dev",
    "build": "npm --workspace client run build",
    "start": "npm --workspace server run start"
  },
  "engines": {
    "node": ">=18"
  }
}

