NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/application-tracker
CORS_ORIGIN=http://localhost:5173

# Firebase Admin (server-side)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-admin-client-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Alternative to the 3 vars above (recommended for local dev on Windows):
# Point to your Firebase Admin SDK JSON file path.
GOOGLE_APPLICATION_CREDENTIALS=

# Optional (Phase 3) email
SENDGRID_API_KEY=
EMAIL_FROM=
APP_BASE_URL=http://localhost:5173

# Phase 2 (Documents + Sharing)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
SHARE_TOKEN_PEPPER=change-me

# Phase 3 (jobs)
ENABLE_JOBS=false
REMINDER_JOB_INTERVAL_MS=60000
DIGEST_JOB_INTERVAL_MS=300000
DIGEST_LOOKAHEAD_HOURS=48
