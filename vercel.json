{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "api/[...all].js",
      "use": "@vercel/node",
      "config": { "maxDuration": 30 }
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "/api/[...all].js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
